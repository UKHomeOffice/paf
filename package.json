{
  "name": "paf",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "main": "index.js",
  "engines": {
    "node": ">=24.18.0 <25.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UKHomeOffice/paf.git"
  },
  "scripts": {
    "start": "node server.js",
    "start:dev": "[ -f .env ] && hof-build watch --env || hof-build watch",
    "test": "NODE_ENV=test yarn run test:lint && yarn run test:unit && yarn run test:ui-integration",
    "test:lint": "eslint . --config ./node_modules/eslint-config-hof/default.js",
    "test:ui-integration": "NODE_ENV=test _mocha \"test/_ui-integration/**/*.spec.js\" --exit",
    "test:unit": "NODE_ENV=test nyc _mocha \"test/_unit/**/*.spec.js\"",
    "build": "hof-build",
    "test:snyk": "snyk config set api=SNYK_TOKEN && snyk test",
    "postinstall": "yarn run build"
  },
  "dependencies": {
    "accessible-autocomplete": "^3.0.1",
    "bl": "^6.1.6",
    "busboy": "^1.6.0",
    "busboy-body-parser": "^0.3.2",
    "form-data": "^4.0.6",
    "hof": "~24.4.0",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "sqs-producer": "^9.0.5",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "chai-subset": "^1.6.0",
    "chromedriver": "^119.0.1",
    "eslint": "^8.57.0",
    "eslint-config-hof": "^1.3.4",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "mock-fs": "^5.5.0",
    "nyc": "^18.0.0",
    "proxyquire": "^2.1.3",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.1",
    "snyk": "^1.1306.0",
    "supertest": "^7.2.2",
    "supertest-session": "^5.0.1"
  },
  "resolutions": {  
    "serialize-javascript": "^7.0.7",
    "dicer": "^0.3.1"

  },
  "mocha": {
    "reporter": "spec",
    "require": "test/setup.js",
    "recursive": "true",
    "timeout": "9000"
  },
  "keywords": [],
  "author": ""
}
